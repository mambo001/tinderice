{
  "name": "tinderice-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "build:web": "bun run build --workspace=apps/web",
    "build:backend": "bun run build --workspace=apps/backend",
    "deploy": "bun run build && wrangler deploy --config apps/backend/wrangler.toml",
    "lint": "bun run --filter '*' lint",
    "test": "bun run --filter '*' test"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20260313.1",
    "effect": "4.0.0-beta.20",
    "wrangler": "^4.73.0"
  }
}
