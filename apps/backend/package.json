{
  "name": "@tinderice-app/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc --noEmit",
    "start": "bun run dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate:local": "wrangler d1 migrations apply Tinderice --local",
    "db:migrate:remote": "wrangler d1 migrations apply Tinderice --remote",
    "db:migrate:create": "wrangler d1 migrations create Tinderice"
  },
  "devDependencies": {
    "bun-types": "^1.3.10",
    "@tinderice-app/shared": "workspace:*"
  }
}
